@page "/positions/searches/new"
@page "/positions/searches/{Id:int}/edit"
@using JobSearchTracker.Core.Entities
@using JobSearchTracker.Core.Enums
@using JobSearchTracker.Data.Services
@using JobSearchTracker.Web.Models
@inject SearchRequestService SearchRequestService
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>@(Id is null ? "Add Search" : "Edit Search")</PageTitle>

<h1>@(Id is null ? "Add Search" : "Edit Search")</h1>

@if (_loading)
{
    <p>Loading...</p>
}
else
{
    <EditForm Model="_model" OnValidSubmit="SaveAsync" class="application-form">
        <DataAnnotationsValidator />

        <div class="form-group">
            <label>Name</label>
            <InputText @bind-Value="_model.Name" placeholder="e.g. QA Manager - Canada" />
            <ValidationMessage For="() => _model.Name" />
        </div>

        <div class="form-group">
            <label>Keywords</label>
            <InputText @bind-Value="_model.Keywords" placeholder="e.g. QA Manager" />
            <ValidationMessage For="() => _model.Keywords" />
        </div>

        <div class="form-group">
            <label>Location</label>
            <InputText @bind-Value="_model.Location" placeholder="e.g. Canada, or Remote" />
            <ValidationMessage For="() => _model.Location" />
        </div>

        <div class="form-group">
            <label>Workplace Type</label>
            <InputSelect @bind-Value="_workplaceTypeValue">
                <option value="">Any</option>
                @foreach (var type in Enum.GetValues<WorkplaceType>())
                {
                    <option value="@type">@type</option>
                }
            </InputSelect>
        </div>

        <div class="form-group">
            <label>Date Posted</label>
            <InputSelect @bind-Value="_model.DatePosted">
                @foreach (var filter in Enum.GetValues<DatePostedFilter>())
                {
                    <option value="@filter">@filter</option>
                }
            </InputSelect>
        </div>

        <div class="form-group form-group-inline">
            <label><InputCheckbox @bind-Value="_model.IsActive" /> Include in "Run All Searches"</label>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Save</button>
            <a class="btn btn-link" href="/positions">Cancel</a>
        </div>
    </EditForm>
}

@code {
    [Parameter] public int? Id { get; set; }

    private readonly SearchRequestFormModel _model = new();
    private bool _loading = true;

    private string _workplaceTypeValue
    {
        get => _model.WorkplaceType?.ToString() ?? "";
        set => _model.WorkplaceType = string.IsNullOrEmpty(value) ? null : Enum.Parse<WorkplaceType>(value);
    }

    protected override async Task OnInitializedAsync()
    {
        if (Id is not null)
        {
            var existing = await SearchRequestService.GetByIdAsync(Id.Value);
            if (existing is not null)
            {
                _model.Name = existing.Name;
                _model.Keywords = existing.Keywords;
                _model.Location = existing.Location;
                _model.WorkplaceType = existing.WorkplaceType;
                _model.DatePosted = existing.DatePosted;
                _model.IsActive = existing.IsActive;
            }
        }
        _loading = false;
    }

    private async Task SaveAsync()
    {
        if (Id is null)
        {
            var request = new SearchRequest
            {
                Name = _model.Name,
                Keywords = _model.Keywords,
                Location = _model.Location,
                WorkplaceType = _model.WorkplaceType,
                DatePosted = _model.DatePosted,
                IsActive = _model.IsActive
            };
            await SearchRequestService.CreateAsync(request);
        }
        else
        {
            var existing = await SearchRequestService.GetByIdAsync(Id.Value);
            if (existing is not null)
            {
                existing.Name = _model.Name;
                existing.Keywords = _model.Keywords;
                existing.Location = _model.Location;
                existing.WorkplaceType = _model.WorkplaceType;
                existing.DatePosted = _model.DatePosted;
                existing.IsActive = _model.IsActive;
                await SearchRequestService.UpdateAsync(existing);
            }
        }

        Nav.NavigateTo("/positions");
    }
}
