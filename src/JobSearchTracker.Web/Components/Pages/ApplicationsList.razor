@page "/"
@using JobSearchTracker.Core.Enums
@using JobSearchTracker.Data.Services
@inject ApplicationService ApplicationService
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>Applications</PageTitle>

<div class="page-header">
    <h1>Job Applications</h1>
    <a class="btn btn-primary" href="/applications/new">+ Add Application</a>
</div>

<div class="filters">
    <input type="text" placeholder="Filter by company..." @bind="_companyFilter" @bind:event="oninput" @onkeyup="ApplyFilterAsync" />

    <select @bind="_sourceFilter" @bind:after="ApplyFilterAsync">
        <option value="">All sources</option>
        @foreach (var source in Enum.GetValues<ApplicationSource>())
        {
            <option value="@source">@source</option>
        }
    </select>

    <input type="date" @bind="_fromDate" @bind:after="ApplyFilterAsync" />
    <span>to</span>
    <input type="date" @bind="_toDate" @bind:after="ApplyFilterAsync" />

    @if (_companyFilter is not null || _sourceFilter is not "" || _fromDate is not null || _toDate is not null)
    {
        <button class="btn btn-link" @onclick="ClearFiltersAsync">Clear filters</button>
    }
</div>

@if (_applications is null)
{
    <p>Loading...</p>
}
else if (_applications.Count == 0)
{
    <p class="empty-state">No applications yet. Click "Add Application" to log your first one.</p>
}
else
{
    <table class="applications-table">
        <thead>
            <tr>
                <th>Company</th>
                <th>Position</th>
                <th>Date</th>
                <th>Source</th>
                <th>Resume Version</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var app in _applications)
            {
                <tr>
                    <td>@app.Company.Name</td>
                    <td>
                        @if (!string.IsNullOrWhiteSpace(app.JobPostingUrl))
                        {
                            <a href="@app.JobPostingUrl" target="_blank" rel="noopener">@(app.PositionTitle ?? "View posting")</a>
                        }
                        else
                        {
                            @(app.PositionTitle ?? "—")
                        }
                    </td>
                    <td>@app.ApplicationDate.ToString("yyyy-MM-dd")</td>
                    <td>
                        <span class="badge">@app.Source</span>
                    </td>
                    <td>@(app.ResumeVersion ?? "—")</td>
                    <td class="actions">
                        <a href="/applications/@app.Id/edit">Edit</a>
                        <button class="btn btn-link btn-danger" @onclick="() => DeleteAsync(app.Id)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<JobSearchTracker.Core.Entities.Application>? _applications;
    private string? _companyFilter;
    private string _sourceFilter = "";
    private DateOnly? _fromDate;
    private DateOnly? _toDate;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        var filter = new ApplicationFilter
        {
            CompanyNameContains = _companyFilter,
            Source = string.IsNullOrEmpty(_sourceFilter) ? null : Enum.Parse<ApplicationSource>(_sourceFilter),
            FromDate = _fromDate,
            ToDate = _toDate
        };
        _applications = await ApplicationService.GetAllAsync(filter);
    }

    private async Task ApplyFilterAsync() => await LoadAsync();

    private async Task ClearFiltersAsync()
    {
        _companyFilter = null;
        _sourceFilter = "";
        _fromDate = null;
        _toDate = null;
        await LoadAsync();
    }

    private async Task DeleteAsync(int id)
    {
        await ApplicationService.DeleteAsync(id);
        await LoadAsync();
    }
}
